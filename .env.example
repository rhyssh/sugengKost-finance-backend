# Supabase
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # pakai service_role key (full access, hanya di backend!)

# Cloudflare R2
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET=kos-bukti-bayar

# JWT (untuk middleware custom kalau perlu, tapi Supabase JWT sudah cukup)
JWT_SECRET=super-secret-key-min-32-char
PORT=8080